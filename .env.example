# --- Server ---
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# --- Security ---
# Ganti dengan random string panjang di production
SESSION_SECRET=change-me-to-a-long-random-string
# Secret untuk signing webhook payload (HMAC-SHA256)
WEBHOOK_SECRET=change-me-webhook-secret

# --- Database ---
DATABASE_URL="file:./dev.db"

# --- Admin awal (dipakai saat seed) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Poller ---
# interval polling mutasi dalam detik
POLLER_INTERVAL_SECONDS=10
# expire invoice dalam menit
INVOICE_EXPIRE_MINUTES=15
