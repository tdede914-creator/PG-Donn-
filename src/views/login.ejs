<!doctype html>
<html>
<head><%- include('partials/head', { title: 'Login' }) %></head>
<body class="bg-slate-100 min-h-screen flex items-center justify-center">
  <form method="POST" action="/login" class="bg-white p-6 rounded-lg shadow w-96 space-y-4">
    <h1 class="text-xl font-bold">Payment Gateway Admin</h1>
    <% if (error) { %>
      <div class="bg-red-100 text-red-700 text-sm px-3 py-2 rounded"><%= error %></div>
    <% } %>
    <div>
      <label class="block text-sm mb-1">Username</label>
      <input name="username" class="w-full border rounded px-3 py-2" autofocus required />
    </div>
    <div>
      <label class="block text-sm mb-1">Password</label>
      <input type="password" name="password" class="w-full border rounded px-3 py-2" required />
    </div>
    <button class="w-full bg-slate-900 text-white py-2 rounded hover:bg-slate-800">Login</button>
  </form>
</body>
</html>
