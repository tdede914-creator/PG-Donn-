<%
  var navItems = [
    { href: '/', key: 'dashboard', label: 'Dashboard' },
    { href: '/invoices', key: 'invoices', label: 'Invoices' },
    { href: '/providers', key: 'providers', label: 'Providers' },
    { href: '/apikeys', key: 'apikeys', label: 'API Keys' },
  ];
%>
<header class="sticky top-0 z-40 border-b border-white/10 bg-ink-900/80 backdrop-blur-lg">
  <div class="mx-auto flex max-w-6xl items-center gap-4 px-4 py-3">
    <a href="/" class="flex items-center gap-2.5">
      <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-brand-500 to-brand-400 shadow-glow">
        <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="5" width="18" height="14" rx="2" /><path d="M3 10h18" /><path d="M7 15h4" />
        </svg>
      </span>
      <span class="leading-tight">
        <span class="block text-sm font-bold text-white">Payment Gateway</span>
        <span class="block text-[10px] font-medium uppercase tracking-wider text-brand-400">Kobong Cloud Server</span>
      </span>
    </a>

    <nav class="ml-4 hidden items-center gap-1 md:flex">
      <% navItems.forEach(function (item) { %>
        <a href="<%= item.href %>"
           class="rounded-lg px-3 py-1.5 text-sm font-medium transition <%= active === item.key ? 'bg-white/10 text-white' : 'text-slate-400 hover:bg-white/5 hover:text-white' %>">
          <%= item.label %>
        </a>
      <% }) %>
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <a href="/account"
         class="hidden items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-3 py-1.5 text-sm text-slate-300 transition hover:text-white sm:flex">
        <span class="flex h-6 w-6 items-center justify-center rounded-full bg-brand-500/20 text-xs font-bold text-brand-300">
          <%= (session.username || '?').charAt(0).toUpperCase() %>
        </span>
        <span class="font-medium"><%= session.username %></span>
      </a>
      <form action="/logout" method="POST">
        <button class="btn btn-ghost px-3 py-1.5 text-sm text-rose-300 hover:text-rose-200">Logout</button>
      </form>
    </div>
  </div>

  <!-- mobile nav -->
  <nav class="flex items-center gap-1 overflow-x-auto border-t border-white/5 px-4 py-2 md:hidden">
    <% navItems.forEach(function (item) { %>
      <a href="<%= item.href %>"
         class="whitespace-nowrap rounded-lg px-3 py-1.5 text-sm font-medium transition <%= active === item.key ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-white' %>">
        <%= item.label %>
      </a>
    <% }) %>
  </nav>
</header>
