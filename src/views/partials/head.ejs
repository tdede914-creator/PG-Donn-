<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="theme-color" content="#070b16" />
<title><%= typeof title !== 'undefined' ? title : 'Payment Gateway' %> · Kobong Cloud</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
  rel="stylesheet"
/>
<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          sans: ['Inter', 'ui-sans-serif', 'system-ui', 'sans-serif'],
          mono: ['"JetBrains Mono"', 'ui-monospace', 'monospace'],
        },
        colors: {
          ink: {
            900: '#060a14',
            800: '#0a1020',
            700: '#0f172a',
            600: '#141d33',
          },
          brand: {
            200: '#bae6fd',
            300: '#7dd3fc',
            400: '#38bdf8',
            500: '#0ea5e9',
            600: '#0284c7',
            700: '#0369a1',
          },
        },
        boxShadow: {
          glow: '0 0 45px -12px rgba(56, 189, 248, 0.55)',
          card: '0 10px 40px -18px rgba(2, 8, 23, 0.9)',
        },
      },
    },
  };
</script>
<style type="text/tailwindcss">
  @layer base {
    body {
      @apply text-slate-200 antialiased;
    }
  }
  @layer components {
    .card {
      @apply rounded-2xl border border-white/10 bg-white/[0.035] shadow-card backdrop-blur-sm;
    }
    .card-hover {
      @apply transition duration-200 hover:border-brand-400/40 hover:bg-white/[0.06];
    }
    .stat-label {
      @apply text-xs font-medium uppercase tracking-wider text-slate-400;
    }
    .stat-value {
      @apply mt-1 text-2xl font-bold text-white;
    }
    .btn {
      @apply inline-flex items-center justify-center gap-2 rounded-xl px-4 py-2 text-sm font-semibold transition disabled:opacity-50;
    }
    .btn-primary {
      @apply bg-gradient-to-r from-brand-500 to-brand-400 text-white shadow-glow hover:from-brand-400 hover:to-brand-400;
    }
    .btn-ghost {
      @apply border border-white/10 bg-white/5 text-slate-200 hover:border-white/20 hover:bg-white/10;
    }
    .btn-danger {
      @apply border border-rose-500/30 bg-rose-500/10 text-rose-300 hover:bg-rose-500/20;
    }
    .input {
      @apply w-full rounded-xl border border-white/10 bg-ink-900/60 px-3 py-2 text-sm text-slate-100 placeholder-slate-500 outline-none transition focus:border-brand-400/60 focus:ring-2 focus:ring-brand-400/20;
    }
    .label {
      @apply mb-1 block text-xs font-medium text-slate-400;
    }
    .badge {
      @apply inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold;
    }
    .badge-paid {
      @apply bg-emerald-500/15 text-emerald-300 ring-1 ring-inset ring-emerald-500/30;
    }
    .badge-pending {
      @apply bg-amber-500/15 text-amber-300 ring-1 ring-inset ring-amber-500/30;
    }
    .badge-expired {
      @apply bg-slate-500/15 text-slate-300 ring-1 ring-inset ring-slate-500/30;
    }
    .badge-cancelled {
      @apply bg-rose-500/15 text-rose-300 ring-1 ring-inset ring-rose-500/30;
    }
    .link {
      @apply text-brand-400 transition hover:text-brand-300;
    }
  }
</style>
<style>
  html {
    scroll-behavior: smooth;
  }
  body {
    min-height: 100vh;
    background-color: #070b16;
    background-image:
      radial-gradient(60rem 60rem at 15% -10%, rgba(14, 165, 233, 0.16), transparent 55%),
      radial-gradient(50rem 50rem at 110% 0%, rgba(56, 189, 248, 0.12), transparent 50%),
      radial-gradient(40rem 40rem at 50% 120%, rgba(2, 132, 199, 0.1), transparent 55%);
    background-attachment: fixed;
  }
  ::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }
  ::-webkit-scrollbar-track {
    background: transparent;
  }
  ::-webkit-scrollbar-thumb {
    background: rgba(148, 163, 184, 0.25);
    border-radius: 9999px;
    border: 2px solid transparent;
    background-clip: content-box;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: rgba(148, 163, 184, 0.4);
    background-clip: content-box;
  }
</style>
