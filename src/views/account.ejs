<!doctype html>
<html>
<head><%- include('partials/head', { title: 'Akun' }) %></head>
<body class="bg-slate-100 min-h-screen">
  <%- include('partials/nav') %>
  <main class="max-w-md mx-auto p-6 space-y-4">
    <h1 class="text-2xl font-bold">Akun</h1>
    <% if (flash) { %><div class="bg-green-100 text-green-700 px-3 py-2 rounded text-sm"><%= flash %></div><% } %>
    <% if (error) { %><div class="bg-red-100 text-red-700 px-3 py-2 rounded text-sm"><%= error %></div><% } %>
    <form method="POST" action="/account/password" class="bg-white p-4 rounded-lg shadow-sm space-y-3 text-sm">
      <h2 class="font-semibold">Ganti Password</h2>
      <div>
        <label class="block mb-1">Password lama</label>
        <input type="password" name="oldPassword" class="w-full border rounded px-3 py-2" required />
      </div>
      <div>
        <label class="block mb-1">Password baru</label>
        <input type="password" name="newPassword" class="w-full border rounded px-3 py-2" required />
      </div>
      <button class="bg-slate-900 text-white px-4 py-2 rounded">Simpan</button>
    </form>
  </main>
</body>
</html>
