<!doctype html>
<html lang="id">
<head><%- include('partials/head', { title: 'Akun' }) %></head>
<body>
  <%- include('partials/nav') %>

  <main class="mx-auto max-w-md space-y-6 px-4 py-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Akun</h1>
      <p class="text-sm text-slate-400">Kelola kredensial admin.</p>
    </div>

    <% if (flash) { %>
      <div class="rounded-xl border border-emerald-500/30 bg-emerald-500/10 px-3 py-2 text-sm text-emerald-300"><%= flash %></div>
    <% } %>
    <% if (error) { %>
      <div class="rounded-xl border border-rose-500/30 bg-rose-500/10 px-3 py-2 text-sm text-rose-300"><%= error %></div>
    <% } %>

    <form method="POST" action="/account/password" class="card space-y-4 p-6">
      <h2 class="font-semibold text-white">Ganti Password</h2>
      <div>
        <label class="label">Password lama</label>
        <input type="password" name="oldPassword" class="input" required />
      </div>
      <div>
        <label class="label">Password baru</label>
        <input type="password" name="newPassword" class="input" required />
      </div>
      <button class="btn btn-primary">Simpan</button>
    </form>
  </main>
</body>
</html>
