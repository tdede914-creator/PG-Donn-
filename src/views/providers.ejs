<!doctype html>
<html lang="id">
<head><%- include('partials/head', { title: 'Providers' }) %></head>
<body>
  <%- include('partials/nav') %>

  <main class="mx-auto max-w-6xl space-y-6 px-4 py-8">
    <div>
      <h1 class="text-2xl font-bold text-white">Providers</h1>
      <p class="text-sm text-slate-400">Konfigurasi akun sumber mutasi QRIS (OrderKuota).</p>
    </div>

    <% if (flash) { %><div class="rounded-xl border border-emerald-500/30 bg-emerald-500/10 px-3 py-2 text-sm text-emerald-300"><%= flash %></div><% } %>
    <% if (error) { %><div class="rounded-xl border border-rose-500/30 bg-rose-500/10 px-3 py-2 text-sm text-rose-300"><%= error %></div><% } %>

    <div class="grid gap-6 lg:grid-cols-2">
      <!-- Add provider -->
      <div class="card p-6">
        <h2 class="mb-4 font-semibold text-white">Tambah Provider Baru</h2>
        <form id="addForm" method="POST" action="/providers" class="space-y-3 text-sm">
          <div>
            <label class="label">Nama</label>
            <input name="name" class="input" placeholder="mis. OK Utama" required />
          </div>
          <div>
            <label class="label">Type</label>
            <select name="type" id="typeSelect" class="input">
              <option value="orderkuota_jywa">OrderKuota — KOBONGCLOUDSERVER (endpoint /qris/mutasi)</option>
            </select>
          </div>

          <!-- OrderKuota OTP Login Panel -->
          <div id="okuLoginPanel" class="space-y-2 rounded-xl border border-brand-400/30 bg-brand-500/5 p-3">
            <div class="text-sm font-semibold text-brand-300">Login OrderKuota (OTP)</div>
            <p class="text-xs text-slate-400">
              Isi username &amp; password OrderKuota. OTP dikirim ke email terdaftar. Setelah verify OTP,
              credentials JSON di bawah terisi otomatis.
            </p>
            <div>
              <label class="label">Username / No HP OrderKuota</label>
              <input id="okuUsername" placeholder="08xxxx" class="input" autocomplete="off" />
            </div>
            <div>
              <label class="label">Password OrderKuota</label>
              <input id="okuPassword" type="password" placeholder="password" class="input" autocomplete="off" />
            </div>
            <button type="button" onclick="requestOtp()" class="btn btn-primary">Kirim OTP ke Email</button>

            <div id="okuOtpPanel" style="display:none" class="mt-2 border-t border-white/10 pt-2">
              <label class="label">Kode OTP (6 digit dari email)</label>
              <div class="flex gap-2">
                <input id="okuOtp" placeholder="123456" maxlength="6" class="input flex-1 font-mono" />
                <button type="button" onclick="verifyOtp()" class="btn btn-primary">Verify OTP</button>
              </div>
            </div>

            <div id="okuLoginResult" class="mt-1 text-xs"></div>
          </div>

          <div>
            <label class="label">Static QRIS String</label>
            <textarea name="qrisStatic" class="input h-24 font-mono text-xs" placeholder="000201010211026..." required></textarea>
            <p class="mt-1 text-xs text-slate-500">Ambil dari aplikasi merchant (scan QR statik → decode → paste stringnya).</p>
          </div>
          <div>
            <label class="label">Credentials (JSON)</label>
            <textarea name="credentials" id="credentialsField" class="input h-40 font-mono text-xs"></textarea>
            <div class="mt-1 flex gap-3">
              <button type="button" onclick="fillTemplate()" class="text-xs link">Isi template berdasarkan Type</button>
              <button type="button" onclick="testPreview()" class="text-xs text-amber-300 hover:text-amber-200">Test connection dulu</button>
            </div>
            <div id="testResult" class="mt-2 text-xs"></div>
          </div>
          <button class="btn btn-primary">Simpan</button>
        </form>
      </div>

      <!-- Registered providers -->
      <div class="card p-6">
        <h2 class="mb-4 font-semibold text-white">Provider Terdaftar</h2>
        <% if (!providers.length) { %>
          <p class="text-sm text-slate-500">Belum ada provider.</p>
        <% } %>
        <ul class="space-y-3">
          <% providers.forEach(function (p) { %>
            <li class="rounded-xl border border-white/10 bg-white/[0.03] p-3" id="prov-<%= p.id %>">
              <div class="flex items-center">
                <div>
                  <div class="font-semibold text-white"><%= p.name %></div>
                  <div class="text-xs text-slate-500"><%= p.type %> · dibuat <%= new Date(p.createdAt).toLocaleDateString('id-ID') %></div>
                </div>
                <span class="badge ml-auto <%= p.isActive ? 'badge-paid' : 'badge-expired' %>"><%= p.isActive ? 'AKTIF' : 'NONAKTIF' %></span>
              </div>
              <div class="mt-2 flex flex-wrap items-center gap-3">
                <button onclick="testProvider(<%= p.id %>)" class="text-xs text-amber-300 hover:text-amber-200">Test</button>
                <button onclick="pollNow(<%= p.id %>)" class="text-xs link">Poll Now (debug)</button>
                <button onclick="editCreds(<%= p.id %>)" class="text-xs text-emerald-300 hover:text-emerald-200">Edit Credentials</button>
                <form method="POST" action="/providers/<%= p.id %>/toggle" class="inline"><button class="text-xs text-slate-400 hover:text-white">Toggle</button></form>
                <form method="POST" action="/providers/<%= p.id %>/delete" class="inline" onsubmit="return confirm('Hapus provider ini?')"><button class="text-xs text-rose-400 hover:text-rose-300">Hapus</button></form>
              </div>
              <div id="test-<%= p.id %>" class="mt-2 text-xs"></div>
              <div id="edit-<%= p.id %>" class="mt-2 text-xs" style="display:none"></div>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>
  </main>

  <script>
    const templates = {
      orderkuota_jywa: JSON.stringify({
        username: "USERNAME_ORDERKUOTA",
        authUsername: "USERNAME_ORDERKUOTA",
        authToken: "AUTO_DIISI_LEWAT_LOGIN_OTP_DI_ATAS",
        appRegId: "AUTO_DIISI_LEWAT_LOGIN_OTP_DI_ATAS",
        phoneUuid: "AUTO_DIISI_LEWAT_LOGIN_OTP_DI_ATAS",
        phoneModel: "sdk_gphone64_x86_64",
        phoneAndroidVersion: "16",
        appVersionCode: "250811",
        appVersionName: "25.08.11"
      }, null, 2),
    };

    function fillTemplate() {
      const type = document.getElementById('typeSelect').value;
      document.getElementById('credentialsField').value = templates[type] || '{}';
    }

    function renderResult(elId, result) {
      const el = document.getElementById(elId);
      if (result.ok) {
        el.innerHTML = '<div class="rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-2 py-1 text-emerald-300">' +
          '✓ ' + (result.message || '') + '</div>' +
          (result.sample && result.sample.length ?
            '<pre class="mt-1 overflow-auto rounded-lg border border-white/10 bg-ink-900/70 p-2 text-[10px] text-slate-300">' +
            JSON.stringify(result.sample, null, 2) + '</pre>' : '');
      } else {
        el.innerHTML = '<div class="whitespace-pre-wrap rounded-lg border border-rose-500/30 bg-rose-500/10 px-2 py-1 text-rose-300">' +
          '✗ ' + (result.message || 'error') + '</div>';
      }
    }

    function enrichCredentialsWithVersion(credsJsonString) {
      try {
        const obj = JSON.parse(credsJsonString);
        obj.appVersionName = obj.appVersionName || "26.06.27";
        obj.appVersionCode = obj.appVersionCode || "260627";
        obj.phoneModel = obj.phoneModel || "25062RN2DY";
        obj.phoneAndroidVersion = obj.phoneAndroidVersion || "15";
        return JSON.stringify(obj, null, 2);
      } catch (_) { return credsJsonString; }
    }

    async function requestOtp() {
      const u = document.getElementById('okuUsername').value.trim();
      const p = document.getElementById('okuPassword').value;
      if (!u || !p) {
        document.getElementById('okuLoginResult').innerHTML =
          '<div class="rounded-lg border border-amber-500/30 bg-amber-500/10 px-2 py-1 text-amber-200">⚠ Isi username dan password dulu</div>';
        return;
      }
      document.getElementById('okuLoginResult').innerHTML =
        '<div class="text-slate-400">Mengirim OTP ke server OrderKuota...</div>';
      try {
        const r = await fetch('/providers/orderkuota/request-otp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ username: u, password: p }),
        });
        const data = await r.json();
        if (data.ok) {
          document.getElementById('okuLoginResult').innerHTML =
            '<div class="rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-2 py-1 text-emerald-300">✓ ' + data.message + '</div>' +
            '<div class="mt-1 text-xs text-slate-400">Cek email OrderKuota kamu, lalu masukkan kode OTP di bawah.</div>';
          document.getElementById('okuOtpPanel').style.display = 'block';
          document.getElementById('okuOtp').focus();
        } else {
          document.getElementById('okuLoginResult').innerHTML =
            '<div class="whitespace-pre-wrap rounded-lg border border-rose-500/30 bg-rose-500/10 px-2 py-1 text-rose-300">✗ ' + data.message + '</div>';
        }
      } catch (e) {
        document.getElementById('okuLoginResult').innerHTML =
          '<div class="rounded-lg border border-rose-500/30 bg-rose-500/10 px-2 py-1 text-rose-300">✗ ' + e.message + '</div>';
      }
    }

    async function verifyOtp() {
      const otp = document.getElementById('okuOtp').value.trim();
      if (!otp) return;
      document.getElementById('okuLoginResult').innerHTML =
        '<div class="text-slate-400">Verifikasi OTP...</div>';
      try {
        const r = await fetch('/providers/orderkuota/verify-otp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ otp: otp }),
        });
        const data = await r.json();
        if (data.ok) {
          document.getElementById('okuLoginResult').innerHTML =
            '<div class="rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-2 py-1 text-emerald-300">✓ ' + data.message + '</div>';
          document.getElementById('credentialsField').value = enrichCredentialsWithVersion(data.credentials);
          document.querySelector('button[type="submit"], form#addForm button.btn-primary')?.scrollIntoView({ behavior: 'smooth' });
        } else {
          document.getElementById('okuLoginResult').innerHTML =
            '<div class="whitespace-pre-wrap rounded-lg border border-rose-500/30 bg-rose-500/10 px-2 py-1 text-rose-300">✗ ' + data.message + '</div>';
        }
      } catch (e) {
        document.getElementById('okuLoginResult').innerHTML =
          '<div class="rounded-lg border border-rose-500/30 bg-rose-500/10 px-2 py-1 text-rose-300">✗ ' + e.message + '</div>';
      }
    }

    async function testPreview() {
      const form = document.getElementById('addForm');
      const fd = new FormData(form);
      document.getElementById('testResult').innerHTML = '<div class="text-slate-400">Testing...</div>';
      try {
        const r = await fetch('/providers/test-preview', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({
            type: fd.get('type'),
            qrisStatic: fd.get('qrisStatic') || '',
            credentials: fd.get('credentials') || '{}',
          }),
        });
        renderResult('testResult', await r.json());
      } catch (e) {
        renderResult('testResult', { ok: false, message: e.message });
      }
    }

    async function testProvider(id) {
      const elId = 'test-' + id;
      document.getElementById(elId).innerHTML = '<div class="text-slate-400">Testing...</div>';
      try {
        const r = await fetch('/providers/' + id + '/test', { method: 'POST' });
        renderResult(elId, await r.json());
      } catch (e) {
        renderResult(elId, { ok: false, message: e.message });
      }
    }

    async function editCreds(id) {
      const elId = 'edit-' + id;
      const el = document.getElementById(elId);
      el.style.display = 'block';
      el.innerHTML = '<div class="text-slate-400">Loading...</div>';
      try {
        const r = await fetch('/providers/' + id + '/credentials');
        const data = await r.json();
        if (!data.ok) { el.innerHTML = '<div class="text-rose-300">Gagal load</div>'; return; }
        const pretty = JSON.stringify(JSON.parse(data.credentials || '{}'), null, 2);
        el.innerHTML =
          '<div class="rounded-xl border border-emerald-500/20 bg-emerald-500/5 p-2">' +
          '<div class="mb-1 text-xs font-semibold text-slate-300">Edit Credentials JSON:</div>' +
          '<textarea id="editCreds-' + id + '" class="input h-56 font-mono text-[10px]">' +
          pretty.replace(/</g, '&lt;') +
          '</textarea>' +
          '<div class="mt-1 text-[10px] text-slate-500">' +
          'Tips: tambah/edit "appVersionName" &amp; "appVersionCode" untuk versi terbaru. ' +
          'Coba: <code>"26.07.14"/"260714"</code>, <code>"99.99.99"/"999999"</code>.' +
          '</div>' +
          '<div class="mt-2 flex gap-2">' +
          '<button onclick="saveCreds(' + id + ')" class="btn btn-primary px-3 py-1 text-xs">Save</button>' +
          '<button onclick="document.getElementById(\'' + elId + '\').style.display=\'none\'" class="btn btn-ghost px-3 py-1 text-xs">Batal</button>' +
          '</div>' +
          '<div id="editResult-' + id + '" class="mt-1 text-xs"></div>' +
          '</div>';
      } catch (e) {
        el.innerHTML = '<div class="text-rose-300">Error: ' + e.message + '</div>';
      }
    }

    async function saveCreds(id) {
      const val = document.getElementById('editCreds-' + id).value;
      const resEl = document.getElementById('editResult-' + id);
      resEl.innerHTML = '<span class="text-slate-400">Saving...</span>';
      try {
        const r = await fetch('/providers/' + id + '/update-credentials', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ credentials: val }),
        });
        const data = await r.json();
        resEl.innerHTML = data.ok
          ? '<span class="text-emerald-300">✓ ' + data.message + ' Sekarang tap "Poll Now" atau "Test".</span>'
          : '<span class="text-rose-300">✗ ' + data.message + '</span>';
      } catch (e) {
        resEl.innerHTML = '<span class="text-rose-300">✗ ' + e.message + '</span>';
      }
    }

    async function pollNow(id) {
      const elId = 'test-' + id;
      document.getElementById(elId).innerHTML = '<div class="text-slate-400">Polling...</div>';
      try {
        const r = await fetch('/providers/' + id + '/poll-now', { method: 'POST' });
        const data = await r.json();
        if (!data.ok) { renderResult(elId, data); return; }
        const el = document.getElementById(elId);
        let html =
          '<div class="rounded-lg border border-brand-400/30 bg-brand-500/10 px-2 py-1 text-brand-300">🔄 ' + data.message + '</div>' +
          '<div class="mt-1 text-xs font-semibold text-slate-300">Sample mutasi terbaru:</div>' +
          '<pre class="max-h-40 overflow-auto rounded-lg border border-white/10 bg-ink-900/70 p-2 text-[10px] text-slate-300">' +
          JSON.stringify(data.sampleMutations, null, 2) + '</pre>' +
          '<div class="mt-1 text-xs font-semibold text-slate-300">Invoice PENDING yang menunggu:</div>' +
          '<pre class="max-h-40 overflow-auto rounded-lg border border-white/10 bg-ink-900/70 p-2 text-[10px] text-slate-300">' +
          JSON.stringify(data.pendingInvoices, null, 2) + '</pre>';
        if (data.debug) {
          html += '<div class="mt-2 text-xs font-semibold text-rose-300">🐛 Debug — Raw Response OrderKuota:</div>' +
            '<div class="text-[10px] text-slate-500">HTTP ' + data.debug.httpStatus +
            ' · Body length ' + data.debug.rawBodyLength +
            ' · Top-level keys: ' + JSON.stringify(data.debug.parsedTopKeys) + '</div>' +
            '<pre class="max-h-80 overflow-auto rounded-lg border border-rose-500/20 bg-rose-500/5 p-2 text-[10px] text-slate-300">' +
            (data.debug.parsedDataPreview || '(no data)') + '</pre>';
        }
        el.innerHTML = html;
      } catch (e) {
        renderResult(elId, { ok: false, message: e.message });
      }
    }
  </script>
</body>
</html>
