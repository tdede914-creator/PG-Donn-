<!doctype html>
<html>
<head><%- include('partials/head', { title: 'Providers' }) %></head>
<body class="bg-slate-100 min-h-screen">
  <%- include('partials/nav') %>
  <main class="max-w-6xl mx-auto p-6 space-y-6">
    <h1 class="text-2xl font-bold">Providers</h1>
    <% if (flash) { %><div class="bg-green-100 text-green-700 px-3 py-2 rounded text-sm"><%= flash %></div><% } %>
    <% if (error) { %><div class="bg-red-100 text-red-700 px-3 py-2 rounded text-sm"><%= error %></div><% } %>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white rounded-lg shadow-sm p-4">
        <h2 class="font-semibold mb-3">Tambah Provider Baru</h2>
        <form id="addForm" method="POST" action="/providers" class="space-y-3 text-sm">
          <div>
            <label class="block mb-1">Nama</label>
            <input name="name" class="w-full border rounded px-3 py-2" placeholder="mis. OK Utama" required />
          </div>
          <div>
            <label class="block mb-1">Type</label>
            <select name="type" id="typeSelect" class="w-full border rounded px-3 py-2">
              <option value="orderkuota">OrderKuota (login pakai OTP - seperti JAGOPAY)</option>
              <option value="okeconnect">OkConnect (scrape pakai session cookie)</option>
              <option value="dana_bisnis">DANA Bisnis</option>
            </select>
          </div>

          <!-- ============= OrderKuota OTP Login Panel ============= -->
          <div id="okuLoginPanel" class="border-2 border-blue-200 bg-blue-50 rounded p-3 space-y-2">
            <div class="font-semibold text-blue-900 text-sm">🔐 Login OrderKuota (OTP)</div>
            <p class="text-xs text-slate-600">
              Isi username &amp; password OrderKuota kamu. OTP akan dikirim ke email
              yang terdaftar di OrderKuota. Setelah verify OTP, credentials JSON di
              bawah akan terisi otomatis.
            </p>
            <div>
              <label class="block mb-1 text-xs">Username / No HP OrderKuota</label>
              <input id="okuUsername" placeholder="08xxxx"
                     class="w-full border rounded px-2 py-1 text-sm" autocomplete="off" />
            </div>
            <div>
              <label class="block mb-1 text-xs">Password OrderKuota</label>
              <input id="okuPassword" type="password" placeholder="password"
                     class="w-full border rounded px-2 py-1 text-sm" autocomplete="off" />
            </div>
            <button type="button" onclick="requestOtp()"
                    class="bg-blue-600 hover:bg-blue-700 text-white px-3 py-1.5 rounded text-sm">
              📧 Kirim OTP ke Email
            </button>

            <div id="okuOtpPanel" style="display:none" class="mt-2 pt-2 border-t border-blue-200">
              <label class="block mb-1 text-xs">Kode OTP (6 digit dari email)</label>
              <div class="flex gap-2">
                <input id="okuOtp" placeholder="123456" maxlength="6"
                       class="flex-1 border rounded px-2 py-1 text-sm font-mono" />
                <button type="button" onclick="verifyOtp()"
                        class="bg-green-600 hover:bg-green-700 text-white px-3 py-1.5 rounded text-sm">
                  ✅ Verify OTP
                </button>
              </div>
            </div>

            <div id="okuLoginResult" class="text-xs mt-1"></div>
          </div>
          <!-- ============= end OrderKuota OTP Panel ============= -->

          <div>
            <label class="block mb-1">Static QRIS String</label>
            <textarea name="qrisStatic" class="w-full border rounded px-3 py-2 h-24 font-mono text-xs" placeholder="000201010211026..." required></textarea>
            <p class="text-xs text-slate-500 mt-1">Ambil dari aplikasi merchant (Scan QR statik-mu → decode → paste stringnya di sini).</p>
          </div>
          <div>
            <label class="block mb-1">Credentials (JSON)</label>
            <textarea name="credentials" id="credentialsField" class="w-full border rounded px-3 py-2 h-40 font-mono text-xs"></textarea>
            <div class="flex gap-2 mt-1">
              <button type="button" onclick="fillTemplate()" class="text-xs text-blue-600 hover:underline">Isi template berdasarkan Type</button>
              <button type="button" onclick="testPreview()" class="text-xs text-amber-600 hover:underline">🔌 Test connection dulu</button>
            </div>
            <div id="testResult" class="mt-2 text-xs"></div>
          </div>
          <button class="bg-slate-900 text-white px-4 py-2 rounded">Simpan</button>
        </form>
      </div>

      <div class="bg-white rounded-lg shadow-sm p-4">
        <h2 class="font-semibold mb-3">Provider Terdaftar</h2>
        <% if (!providers.length) { %>
          <p class="text-slate-500 text-sm">Belum ada provider.</p>
        <% } %>
        <ul class="space-y-3">
          <% providers.forEach(function(p) { %>
            <li class="border rounded p-3" id="prov-<%= p.id %>">
              <div class="flex items-center">
                <div>
                  <div class="font-semibold"><%= p.name %></div>
                  <div class="text-xs text-slate-500"><%= p.type %> · dibuat <%= new Date(p.createdAt).toLocaleDateString('id-ID') %></div>
                </div>
                <span class="ml-auto px-2 py-0.5 text-xs rounded <%= p.isActive ? 'bg-green-100 text-green-700' : 'bg-slate-200 text-slate-600' %>"><%= p.isActive ? 'AKTIF' : 'NONAKTIF' %></span>
              </div>
              <div class="mt-2 flex gap-2 items-center flex-wrap">
                <button onclick="testProvider(<%= p.id %>)" class="text-xs text-amber-600 hover:text-amber-800">🔌 Test</button>
                <button onclick="pollNow(<%= p.id %>)" class="text-xs text-blue-600 hover:text-blue-800">🔄 Poll Now (debug)</button>
                <button onclick="editCreds(<%= p.id %>)" class="text-xs text-green-600 hover:text-green-800">✏️ Edit Credentials</button>
                <form method="POST" action="/providers/<%= p.id %>/toggle" class="inline"><button class="text-xs text-slate-600 hover:text-slate-900">Toggle</button></form>
                <form method="POST" action="/providers/<%= p.id %>/delete" class="inline" onsubmit="return confirm('Hapus provider ini?')"><button class="text-xs text-red-600 hover:text-red-800">Hapus</button></form>
              </div>
              <div id="test-<%= p.id %>" class="mt-2 text-xs"></div>
              <div id="edit-<%= p.id %>" class="mt-2 text-xs" style="display:none"></div>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>
  </main>

  <script>
    const templates = {
      orderkuota: JSON.stringify({
        username: "AUTO_DIISI_LEWAT_LOGIN_OTP_DI_ATAS",
        authToken: "AUTO_DIISI_LEWAT_LOGIN_OTP_DI_ATAS",
        authUsername: "AUTO_DIISI_LEWAT_LOGIN_OTP_DI_ATAS",
        appRegId: "AUTO_DIISI_LEWAT_LOGIN_OTP_DI_ATAS"
      }, null, 2),
      okeconnect: JSON.stringify({
        sessionCookie: "PASTE_VALUE_ci_session_DARI_LAPTOP_F12",
        cookieName: "ci_session",
        mutasiUrl: "https://okeconnect.com/mutasi",
        maxPages: 1,
        descFilter: "Pencairan QRIS"
      }, null, 2),
      dana_bisnis: JSON.stringify({
        endpoint: "https://api-partner.dana.id/v1/merchant/transaction/history",
        method: "POST",
        headers: {
          "Authorization": "Bearer TOKEN_DARI_F12",
          "X-Signature": "SIGNATURE_DARI_F12"
        },
        body: { startDate: "AUTO_TODAY", endDate: "AUTO_TODAY" },
        resultsPath: "data.transactions"
      }, null, 2),
    };

    function fillTemplate() {
      const type = document.getElementById('typeSelect').value;
      document.getElementById('credentialsField').value = templates[type] || '{}';
    }

    function toggleOkuPanel() {
      const type = document.getElementById('typeSelect').value;
      document.getElementById('okuLoginPanel').style.display =
        type === 'orderkuota' ? 'block' : 'none';
    }

    document.getElementById('typeSelect').addEventListener('change', toggleOkuPanel);
    toggleOkuPanel();  // init

    function renderResult(elId, result) {
      const el = document.getElementById(elId);
      if (result.ok) {
        el.innerHTML = '<div class="bg-green-100 text-green-700 px-2 py-1 rounded">' +
          '✓ ' + (result.message || '') + '</div>' +
          (result.sample && result.sample.length ?
            '<pre class="mt-1 bg-slate-50 p-2 rounded text-[10px] overflow-auto">' +
            JSON.stringify(result.sample, null, 2) + '</pre>' : '');
      } else {
        el.innerHTML = '<div class="bg-red-100 text-red-700 px-2 py-1 rounded whitespace-pre-wrap">' +
          '✗ ' + (result.message || 'error') + '</div>';
      }
    }

    // Setelah verify OTP sukses, tambah field appVersionName + appVersionCode
    // ke credentials JSON. Ini biar user aware field ini ada, dan bisa update
    // waktu OK naikin versi minimum lagi di masa depan.
    function enrichCredentialsWithVersion(credsJsonString) {
      try {
        const obj = JSON.parse(credsJsonString);
        if (!obj.appVersionName) obj.appVersionName = "26.06.27";
        if (!obj.appVersionCode) obj.appVersionCode = "260627";
        return JSON.stringify(obj, null, 2);
      } catch (_) { return credsJsonString; }
    }

    // --- OrderKuota OTP flow ---
    async function requestOtp() {
      const u = document.getElementById('okuUsername').value.trim();
      const p = document.getElementById('okuPassword').value;
      if (!u || !p) {
        document.getElementById('okuLoginResult').innerHTML =
          '<div class="bg-amber-100 text-amber-800 px-2 py-1 rounded">⚠ Isi username dan password dulu</div>';
        return;
      }
      document.getElementById('okuLoginResult').innerHTML =
        '<div class="text-slate-500">Mengirim OTP ke server OrderKuota...</div>';
      try {
        const r = await fetch('/providers/orderkuota/request-otp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ username: u, password: p }),
        });
        const data = await r.json();
        if (data.ok) {
          document.getElementById('okuLoginResult').innerHTML =
            '<div class="bg-green-100 text-green-700 px-2 py-1 rounded">✓ ' + data.message + '</div>' +
            '<div class="text-xs text-slate-600 mt-1">Cek email OrderKuota kamu, terus masukkan kode OTP di bawah.</div>';
          document.getElementById('okuOtpPanel').style.display = 'block';
          document.getElementById('okuOtp').focus();
        } else {
          document.getElementById('okuLoginResult').innerHTML =
            '<div class="bg-red-100 text-red-700 px-2 py-1 rounded whitespace-pre-wrap">✗ ' + data.message + '</div>';
        }
      } catch (e) {
        document.getElementById('okuLoginResult').innerHTML =
          '<div class="bg-red-100 text-red-700 px-2 py-1 rounded">✗ ' + e.message + '</div>';
      }
    }

    async function verifyOtp() {
      const otp = document.getElementById('okuOtp').value.trim();
      if (!otp) return;
      document.getElementById('okuLoginResult').innerHTML =
        '<div class="text-slate-500">Verifikasi OTP...</div>';
      try {
        const r = await fetch('/providers/orderkuota/verify-otp', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ otp: otp }),
        });
        const data = await r.json();
        if (data.ok) {
          document.getElementById('okuLoginResult').innerHTML =
            '<div class="bg-green-100 text-green-700 px-2 py-1 rounded">✓ ' + data.message + '</div>';
          document.getElementById('credentialsField').value = enrichCredentialsWithVersion(data.credentials);
          // Scroll ke tombol Simpan
          document.querySelector('button[type="submit"], form#addForm button.bg-slate-900')?.scrollIntoView({ behavior: 'smooth' });
        } else {
          document.getElementById('okuLoginResult').innerHTML =
            '<div class="bg-red-100 text-red-700 px-2 py-1 rounded whitespace-pre-wrap">✗ ' + data.message + '</div>';
        }
      } catch (e) {
        document.getElementById('okuLoginResult').innerHTML =
          '<div class="bg-red-100 text-red-700 px-2 py-1 rounded">✗ ' + e.message + '</div>';
      }
    }

    // --- Test connection (existing) ---
    async function testPreview() {
      const form = document.getElementById('addForm');
      const fd = new FormData(form);
      document.getElementById('testResult').innerHTML =
        '<div class="text-slate-500">Testing...</div>';
      try {
        const r = await fetch('/providers/test-preview', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({
            type: fd.get('type'),
            qrisStatic: fd.get('qrisStatic') || '',
            credentials: fd.get('credentials') || '{}',
          }),
        });
        renderResult('testResult', await r.json());
      } catch (e) {
        renderResult('testResult', { ok: false, message: e.message });
      }
    }

    async function testProvider(id) {
      const elId = 'test-' + id;
      document.getElementById(elId).innerHTML =
        '<div class="text-slate-500">Testing...</div>';
      try {
        const r = await fetch('/providers/' + id + '/test', { method: 'POST' });
        renderResult(elId, await r.json());
      } catch (e) {
        renderResult(elId, { ok: false, message: e.message });
      }
    }

    async function editCreds(id) {
      const elId = 'edit-' + id;
      const el = document.getElementById(elId);
      el.style.display = 'block';
      el.innerHTML = '<div class="text-slate-500">Loading...</div>';
      try {
        const r = await fetch('/providers/' + id + '/credentials');
        const data = await r.json();
        if (!data.ok) { el.innerHTML = '<div class="text-red-700">Gagal load</div>'; return; }
        const pretty = JSON.stringify(JSON.parse(data.credentials || '{}'), null, 2);
        el.innerHTML =
          '<div class="border rounded p-2 bg-green-50">' +
          '<div class="text-xs font-semibold mb-1">Edit Credentials JSON:</div>' +
          '<textarea id="editCreds-' + id + '" class="w-full border rounded px-2 py-1 font-mono text-[10px] h-56">' +
          pretty.replace(/</g, '&lt;') +
          '</textarea>' +
          '<div class="mt-1 text-[10px] text-slate-600">' +
          '💡 Tips: tambah/edit "appVersionName" dan "appVersionCode" untuk versi terbaru. ' +
          'Coba: <code>"26.07.14"/"260714"</code>, <code>"26.08.01"/"260801"</code>, atau <code>"99.99.99"/"999999"</code>.' +
          '</div>' +
          '<div class="mt-2 flex gap-2">' +
          '<button onclick="saveCreds(' + id + ')" class="text-xs bg-green-600 text-white px-2 py-1 rounded">💾 Save</button>' +
          '<button onclick="document.getElementById(\'' + elId + '\').style.display=\'none\'" class="text-xs text-slate-600">Batal</button>' +
          '</div>' +
          '<div id="editResult-' + id + '" class="mt-1 text-xs"></div>' +
          '</div>';
      } catch (e) {
        el.innerHTML = '<div class="text-red-700">Error: ' + e.message + '</div>';
      }
    }

    async function saveCreds(id) {
      const val = document.getElementById('editCreds-' + id).value;
      const resEl = document.getElementById('editResult-' + id);
      resEl.innerHTML = '<span class="text-slate-500">Saving...</span>';
      try {
        const r = await fetch('/providers/' + id + '/update-credentials', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ credentials: val }),
        });
        const data = await r.json();
        resEl.innerHTML = data.ok
          ? '<span class="text-green-700">✓ ' + data.message + ' Sekarang tap "Poll Now" atau "Test".</span>'
          : '<span class="text-red-700">✗ ' + data.message + '</span>';
      } catch (e) {
        resEl.innerHTML = '<span class="text-red-700">✗ ' + e.message + '</span>';
      }
    }

    async function pollNow(id) {
      const elId = 'test-' + id;
      document.getElementById(elId).innerHTML =
        '<div class="text-slate-500">Polling...</div>';
      try {
        const r = await fetch('/providers/' + id + '/poll-now', { method: 'POST' });
        const data = await r.json();
        if (!data.ok) {
          renderResult(elId, data);
          return;
        }
        const el = document.getElementById(elId);
        let html =
          '<div class="bg-blue-100 text-blue-800 px-2 py-1 rounded">' +
          '🔄 ' + data.message + '</div>' +
          '<div class="mt-1 font-semibold text-xs">Sample mutasi terbaru (dari OK):</div>' +
          '<pre class="bg-slate-50 p-2 rounded text-[10px] overflow-auto max-h-40">' +
          JSON.stringify(data.sampleMutations, null, 2) + '</pre>' +
          '<div class="mt-1 font-semibold text-xs">Invoice PENDING yang menunggu:</div>' +
          '<pre class="bg-slate-50 p-2 rounded text-[10px] overflow-auto max-h-40">' +
          JSON.stringify(data.pendingInvoices, null, 2) + '</pre>';
        if (data.debug) {
          html += '<div class="mt-2 font-semibold text-xs text-red-700">🐛 Debug — Raw Response OrderKuota:</div>' +
            '<div class="text-[10px] text-slate-600">HTTP ' + data.debug.httpStatus +
            ' · Body length ' + data.debug.rawBodyLength +
            ' · Top-level keys: ' + JSON.stringify(data.debug.parsedTopKeys) + '</div>' +
            '<pre class="bg-red-50 p-2 rounded text-[10px] overflow-auto max-h-80 border border-red-200">' +
            (data.debug.parsedDataPreview || '(no data)') + '</pre>';
        }
        el.innerHTML = html;
      } catch (e) {
        renderResult(elId, { ok: false, message: e.message });
      }
    }
  </script>
</body>
</html>
