<!doctype html>
<html lang="id">
<head><%- include('partials/head', { title: invoice.reference }) %></head>
<body>
  <%- include('partials/nav') %>

  <main class="mx-auto max-w-5xl space-y-6 px-4 py-8">
    <div class="flex flex-wrap items-center gap-3">
      <a href="/invoices" class="link text-sm">&larr; Invoices</a>
      <h1 class="font-mono text-xl font-bold text-white"><%= invoice.reference %></h1>
      <%- include('partials/status-badge', { status: invoice.status }) %>
      <a class="btn btn-ghost ml-auto" href="/pay/<%= invoice.reference %>" target="_blank">
        Buka halaman bayar
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
      <!-- Detail -->
      <section class="card p-6">
        <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-400">Detail Invoice</h2>
        <dl class="divide-y divide-white/5 text-sm">
          <% function row(label, value, mono) { %>
            <div class="flex items-start justify-between gap-4 py-2.5">
              <dt class="text-slate-400"><%= label %></dt>
              <dd class="text-right <%= mono ? 'font-mono text-xs' : '' %> text-slate-100"><%- value %></dd>
            </div>
          <% } %>
          <% row('Amount', 'Rp ' + invoice.amount.toLocaleString('id-ID')) %>
          <% row('Kode unik', String(invoice.uniqueCode)) %>
          <div class="flex items-start justify-between gap-4 py-2.5">
            <dt class="text-slate-400">Total (bayar)</dt>
            <dd class="text-right text-base font-bold text-brand-300">Rp <%= invoice.totalAmount.toLocaleString('id-ID') %></dd>
          </div>
          <% row('Merchant ref', invoice.merchantRef || '—', true) %>
          <% row('Description', invoice.description || '—') %>
          <% row('Provider', invoice.provider ? (invoice.provider.name + ' (' + invoice.provider.type + ')') : '—') %>
          <% row('API Key', invoice.apiKey ? invoice.apiKey.label : '—') %>
          <div class="flex items-start justify-between gap-4 py-2.5">
            <dt class="text-slate-400">Callback URL</dt>
            <dd class="max-w-[60%] break-all text-right text-xs text-slate-400"><%= invoice.callbackUrl || '—' %></dd>
          </div>
          <% row('Dibuat', new Date(invoice.createdAt).toLocaleString('id-ID')) %>
          <% row('Kadaluarsa', new Date(invoice.expiredAt).toLocaleString('id-ID')) %>
          <% if (invoice.paidAt) { %>
            <% row('Dibayar', new Date(invoice.paidAt).toLocaleString('id-ID')) %>
          <% } %>
        </dl>
      </section>

      <!-- QRIS string -->
      <section class="card p-6">
        <div class="mb-3 flex items-center justify-between">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-400">QRIS String</h2>
          <button type="button" onclick="copyQris(this)" class="btn btn-ghost px-3 py-1 text-xs">Salin</button>
        </div>
        <textarea id="qrisString" readonly class="input h-40 resize-none font-mono text-xs"><%= invoice.qrisDynamic %></textarea>
        <p class="mt-2 text-xs text-slate-500">String QRIS dinamis (EMVCo TLV) untuk nominal <b class="text-slate-300">Rp <%= invoice.totalAmount.toLocaleString('id-ID') %></b>.</p>
      </section>
    </div>

    <!-- Webhook logs -->
    <section class="card overflow-hidden">
      <div class="border-b border-white/10 px-5 py-4">
        <h2 class="font-semibold text-white">Webhook Logs</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-xs uppercase tracking-wider text-slate-500">
              <th class="px-5 py-3 font-medium">Waktu</th>
              <th class="px-5 py-3 font-medium">URL</th>
              <th class="px-5 py-3 font-medium">Attempt</th>
              <th class="px-5 py-3 font-medium">Status</th>
              <th class="px-5 py-3 font-medium">Response</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/5">
            <% invoice.webhookLogs.forEach(function (log) { %>
              <tr class="align-top transition hover:bg-white/[0.03]">
                <td class="whitespace-nowrap px-5 py-3 text-slate-400"><%= new Date(log.createdAt).toLocaleString('id-ID') %></td>
                <td class="max-w-xs break-all px-5 py-3 text-slate-300"><%= log.url %></td>
                <td class="px-5 py-3 text-slate-400"><%= log.attempt %></td>
                <td class="px-5 py-3 <%= log.success ? 'text-emerald-400' : 'text-rose-400' %>">
                  <%= log.success ? 'OK' : 'FAIL' %> <%= log.responseStatus || '' %>
                </td>
                <td class="max-w-xs break-all px-5 py-3 text-xs text-slate-500"><%= (log.responseBody || '').slice(0, 200) %></td>
              </tr>
            <% }) %>
            <% if (!invoice.webhookLogs.length) { %>
              <tr><td class="px-5 py-8 text-center text-slate-500" colspan="5">Belum ada webhook log.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <script>
    function copyQris(btn) {
      const ta = document.getElementById('qrisString');
      navigator.clipboard.writeText(ta.value).then(function () {
        const t = btn.textContent;
        btn.textContent = 'Tersalin ✓';
        setTimeout(function () { btn.textContent = t; }, 1500);
      });
    }
  </script>
</body>
</html>
